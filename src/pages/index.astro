---
import SiteLayout from "../layouts/SiteLayout.astro";
import { internalPages, personalInfo, quickDestinations, snapshotItems } from "../data/site";

const coreTopics = ["RAG systems", "Graph learning", "Knowledge tools"];
---

<SiteLayout
  title="Home"
  description={`${personalInfo.name} is a machine learning builder working on retrieval systems, graph learning, and knowledge tools.`}
>
  <section class="page-section hero-simple">
    <div class="container hero-simple-grid">
      <div class="hero-main">
        <p class="eyebrow">Personal node</p>
        <h1>{personalInfo.name}</h1>
        <p class="hero-role">
          <span>Machine learning engineer</span>
          <span>Computer science master's student</span>
        </p>
        <p class="hero-lead">{personalInfo.subtitle}</p>
        <p class="hero-body">
          I am currently studying at {personalInfo.affiliation} in {personalInfo.location}. I like
          building AI systems that are useful, testable, and easier for people to navigate.
        </p>
        <div class="topic-row" aria-label="Core topics">
          {coreTopics.map((topic) => (
            <span class="topic-pill">{topic}</span>
          ))}
        </div>
      </div>
      <aside class="identity-card profile-card">
        <div class="profile-photo-wrap">
          <img
            class="profile-photo"
            src="/images/yikai-portrait.jpg"
            alt={`Portrait of ${personalInfo.name}`}
          />
        </div>
        <div class="identity-top">
          <div>
            <strong>{personalInfo.name}</strong>
            <p>{personalInfo.affiliation}</p>
          </div>
        </div>
        <div class="profile-meta">
          <div>
            <span class="card-label">Based in</span>
            <p>{personalInfo.location}</p>
          </div>
          <div>
            <span class="card-label">Working on</span>
            <p>Retrieval quality, graph models, and information-rich tools.</p>
          </div>
        </div>
        <div class="identity-links">
          <a href={`mailto:${personalInfo.email}`}>{personalInfo.email}</a>
          <a href={personalInfo.github} target="_blank" rel="noopener">GitHub</a>
        </div>
      </aside>
    </div>
  </section>

  <section class="page-section glance-section">
    <div class="container">
      <div class="section-heading compact-heading">
        <p class="section-kicker">At a glance</p>
        <h2>Who I am and what I do.</h2>
      </div>
      <div class="snapshot-grid">
        {snapshotItems.map((item) => (
          <article class="info-card">
            <span class="card-label">{item.label}</span>
            <p>{item.value}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="container">
      <div class="section-heading compact-heading">
        <p class="section-kicker">Main destinations</p>
        <h2>Go straight to the places that matter.</h2>
      </div>
      <div class="destination-grid featured-grid">
        {quickDestinations.map((item) => (
          <article class="destination-card destination-card-strong">
            <div>
              <span class="card-label">{item.title}</span>
              <p>{item.description}</p>
            </div>
            <a href={item.href} target="_blank" rel="noopener" class="external-link">
              <span>{item.cta}</span>
              <span class="external-icon" aria-hidden="true">↗</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="container">
      <div class="section-heading compact-heading">
        <p class="section-kicker">More about me</p>
        <h2>Open a subpage if you want the longer version.</h2>
      </div>
      <div class="subpage-grid">
        {internalPages.map((item) => (
          <article class="subpage-card">
            <div>
              <span class="card-label">{item.title}</span>
              <p>{item.description}</p>
            </div>
            <a href={item.href}>Open page</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>
